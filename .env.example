APP_NAME=CaiBao
APP_VERSION=0.1.0
APP_ENV=dev
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./CaiBao.db

LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=30

# Docker tip (if you run inside container with /data volume):
# DATABASE_URL=sqlite:////data/CaiBao.db
